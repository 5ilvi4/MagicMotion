platform :ios, '16.0'

use_frameworks!

target 'MagicMotion' do
  # MediaPipe Tasks Vision — Google's pose detection
  # 33 landmarks, faster & more accurate than Apple Vision
  pod 'MediaPipeTasksVision'
  
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    target.build_configurations.each do |config|
      config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] ||= [
        '$(inherited)',
        'MEDIAPIPE_GPU=0',
      ]
      config.build_settings['CLANG_CXX_LANGUAGE_STANDARD'] = 'c++17'
      config.build_settings['OTHER_LDFLAGS'] ||= []
      config.build_settings['OTHER_LDFLAGS'] << '-lc++'

      # Ensure force_load for MediaPipeTasksCommon for device and simulator
      config_name = config.name.downcase
      if config_name.include?('debug') || config_name.include?('release')
        config.build_settings['OTHER_LDFLAGS[sdk=iphoneos*]'] = "$(inherited) -force_load \"${PODS_ROOT}/MediaPipeTasksCommon/frameworks/graph_libraries/libMediaPipeTasksCommon_device_graph.a\""
        config.build_settings['OTHER_LDFLAGS[sdk=iphonesimulator*]'] = "$(inherited) -force_load \"${PODS_ROOT}/MediaPipeTasksCommon/frameworks/graph_libraries/libMediaPipeTasksCommon_simulator_graph.a\""
      end
    end
  end
end
