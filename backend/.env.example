# Environment Configuration
# Copy to .env and fill in values before running.
# Never commit .env to source control.

# ── Server ────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:4000

# ── PostgreSQL ────────────────────────────────────────────────
DATABASE_URL=postgres://user:password@localhost:5432/motionmind
# For production RDS / Heroku Postgres, paste the full connection string here.

# ── Redis (Bull job queue + rate-limit cache) ─────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# ── OAuth2 (Google) ───────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=https://api.motionmind.app/api/auth/google/callback

# ── AWS S3 (report storage) ───────────────────────────────────
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=motionmind-reports

# ── Rate Limiting ─────────────────────────────────────────────
UPLOAD_RATE_LIMIT_PER_DAY=100    # max session uploads per therapist per day
API_RATE_LIMIT_PER_MIN=60        # max API requests per minute per IP

# ── Data Retention (days) ─────────────────────────────────────
GDPR_SOFT_DELETE_EXPIRY_DAYS=30
ARCHIVE_AFTER_YEARS=7
